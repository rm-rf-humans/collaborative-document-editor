%%{init: {
  "theme": "base",
  "themeVariables": {
    "fontFamily": "Helvetica, Arial, sans-serif",
    "primaryColor": "#F7F2E8",
    "primaryTextColor": "#183230",
    "primaryBorderColor": "#2E615D",
    "lineColor": "#527A76",
    "secondaryColor": "#EDF4F2",
    "tertiaryColor": "#FFF8F0",
    "background": "#FFFFFF"
  },
  "flowchart": {
    "curve": "basis",
    "nodeSpacing": 38,
    "rankSpacing": 58
  }
}}%%
flowchart LR
    user["User<br/>Collaborator, owner, or admin"]:::actor
    idp["Identity Provider<br/>OIDC / SAML"]:::external
    llm["LLM Provider<br/>Hosted model APIs"]:::external

    subgraph system["CollabWrite Containers"]
        direction LR

        web["Web App<br/>React + Vite<br/>Editor UI, AI panel, sharing, version history"]:::container

        subgraph runtime["Node.js Runtime Boundary"]
            direction TB
            api["Application API<br/>Express + TypeScript<br/>Auth, document CRUD, sharing, versioning"]:::container
            realtime["Realtime Gateway<br/>WebSocket collaboration hub<br/>Presence and live content fan-out"]:::container
            aiworker["AI Worker / Queue<br/>Async orchestration layer<br/>Prompt assembly, quota checks, completion events"]:::container
        end

        db[("Document Store<br/>PostgreSQL target<br/>In-memory adapter in PoC")]:::storage
        cache[("Collaboration Cache<br/>Redis target<br/>Optional for presence and fan-out")]:::storage
    end

    user -->|"HTTPS / JSON"| web
    web -->|"document CRUD, sharing, AI requests"| api
    web -->|"presence join, live updates, AI completion events"| realtime

    api -->|"verify identity and tenant claims"| idp
    api -->|"persist documents, permissions, versions, sessions"| db
    realtime -->|"load snapshots and update collaborator counts"| db
    realtime -->|"presence fan-out and room state"| cache
    api -->|"enqueue AI work"| aiworker
    aiworker -->|"scoped prompt execution"| llm
    aiworker -->|"persist interaction status"| db
    aiworker -->|"publish completion events"| realtime

    classDef actor fill:#F3E8CF,stroke:#8A6C30,stroke-width:1.5px,color:#3B2D0C;
    classDef container fill:#EAF4F1,stroke:#2E615D,stroke-width:1.8px,color:#183230;
    classDef external fill:#F9F4EC,stroke:#A88955,stroke-width:1.4px,color:#3B2D0C;
    classDef storage fill:#FFF8F0,stroke:#B78452,stroke-width:1.6px,color:#4B3212;
    style system fill:#FFFFFF,stroke:#2E615D,stroke-width:1.6px,stroke-dasharray: 6 4;
    style runtime fill:#FCF8F2,stroke:#6F938F,stroke-width:1.2px,stroke-dasharray: 4 3;
