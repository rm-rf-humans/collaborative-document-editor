    "primaryTextColor": "#183230",
    "primaryBorderColor": "#2E615D",
    "lineColor": "#527A76",
    "secondaryColor": "#EDF4F2",
    "tertiaryColor": "#FFF8F0",
    "background": "#FFFFFF"
  },
  "flowchart": {
    "curve": "basis",
