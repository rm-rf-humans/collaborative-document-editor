flowchart LR
    collaborator["Collaborator<br/>Creates, edits, comments, and reviews AI output"]:::actor
    teamlead["Team Lead / Owner<br/>Manages sharing, reviews history, and reverts changes"]:::actor
    orgadmin["Organization Admin<br/>Controls tenant policy, AI access, and compliance"]:::actor

    idp["Identity Provider<br/>OIDC / SAML identities and tenant claims"]:::external
    llm["LLM Provider<br/>Rewrite, summarize, translate, and restructure requests"]:::external
    export["Export Targets<br/>PDF, DOCX, and Markdown consumers"]:::external

    subgraph boundary["CollabWrite System Boundary"]
        direction TB
        collabwrite["CollabWrite Platform<br/>Real-time collaborative editor with AI writing assistant"]:::system
    end

    collaborator -->|"edit content, follow presence, request AI"| collabwrite
    teamlead -->|"review versions, share documents, audit AI usage"| collabwrite
    orgadmin -->|"configure policy, retention, and feature availability"| collabwrite

    collabwrite -->|"authenticate sessions and resolve org membership"| idp
    collabwrite -->|"send scoped text and prompt metadata for AI operations"| llm
    collabwrite -->|"export point-in-time snapshots and tracked changes"| export

    classDef actor fill:#F3E8CF,stroke:#8A6C30,stroke-width:1.5px,color:#3B2D0C;
    classDef system fill:#EAF4F1,stroke:#2E615D,stroke-width:2px,color:#183230;
    classDef external fill:#F9F4EC,stroke:#A88955,stroke-width:1.4px,color:#3B2D0C;
    style boundary fill:#FFFFFF,stroke:#2E615D,stroke-width:1.6px,stroke-dasharray: 6 4;
