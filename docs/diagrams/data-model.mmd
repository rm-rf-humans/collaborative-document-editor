classDiagram
    direction TB

    class User {
        id: string [PK]
        email: string
        displayName: string
        globalRole: string
        avatarColor: string
    }

    class Session {
        token: string [PK]
        userId: string [FK]
        expiresAt: datetime
    }

    class Document {
        id: string [PK]
        ownerId: string [FK]
        title: string
        content: text
        currentVersion: int
        activeCollaborators: int
        createdAt: datetime
        updatedAt: datetime
    }

    class DocAccess {
        id: string [PK]
        documentId: string [FK]
        principalType: string
        principalId: string
        role: string
        allowAi: bool
        createdAt: datetime
    }

    class DocVersion {
        id: string [PK]
        documentId: string [FK]
        versionNumber: int
        content: text
        createdBy: string [FK]
        reason: string
        createdAt: datetime
    }

    class AiRequest {
        id: string [PK]
        documentId: string [FK]
        initiatedBy: string [FK]
        feature: string
        status: string
        selectionStart: int
        selectionEnd: int
        sourceText: text
        suggestedText: text
        targetLanguage: string
        requestedVersion: int
        promptTemplateVersion: string
        model: string
        quotaConsumed: int
        createdAt: datetime
        completedAt: datetime
    }

    User "1" --> "0..*" Session : opens
    User "1" --> "0..*" Document : owns
    User "1" --> "0..*" DocVersion : writes
    User "1" --> "0..*" AiRequest : requests
    Document "1" --> "0..*" DocAccess : grants
    Document "1" --> "0..*" DocVersion : records
    Document "1" --> "0..*" AiRequest : tracks
